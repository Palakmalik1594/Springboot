package com.capgemini.springbootbasic;

public class Car {
	String brand;
	
	@Override
	public String toString() {
		return "Car [brand=" + brand + ", price=" + price + ", engine=" + engine + "]";
	}


	public Car(String brand, double price, Engine engine) {
		super();
		this.brand = brand;
		this.price = price;
		this.engine = engine;
	}


	double price;
	
	
	Engine engine;
	

}
